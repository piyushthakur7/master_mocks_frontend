# Send browsers straight to the backend instead of proxying through this
# app. The proxy funnels every user's traffic through this server's single
# IP, which is what was hitting Hostinger's per-IP rate limits — direct
# calls give each user their own bucket. Backend CORS was fixed 2026-07-19
# to accept this origin. Not a secret: this value is inlined into the
# public JS bundle regardless of where it's set.
NEXT_PUBLIC_API_URL=https://backend.mastermocks.in/api/v1
